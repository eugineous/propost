# ============================================================
# ProPost Empire — Environment Variables
# Copy this file to .env.local for local development.
# All production values go in Vercel environment variables.
# NEVER commit real values to git.
# ============================================================

# ── Database ──────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host/propost?sslmode=require

# ── AI Providers ──────────────────────────────────────────────
GEMINI_API_KEY=AIza...
NVIDIA_API_KEY=nvapi-...

# ── Cloudflare Worker Auth ────────────────────────────────────
# Must match the CRON_SECRET secret set in wrangler
CRON_SECRET=your-strong-random-secret-here
# Must match the INTERNAL_SECRET secret set in wrangler
INTERNAL_SECRET=your-strong-random-internal-secret-here

# ── X / Twitter ───────────────────────────────────────────────
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
X_WEBHOOK_SECRET=

# ── Instagram ─────────────────────────────────────────────────
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=
INSTAGRAM_APP_SECRET=
INSTAGRAM_WEBHOOK_VERIFY_TOKEN=

# ── Facebook ──────────────────────────────────────────────────
FACEBOOK_ACCESS_TOKEN=
FACEBOOK_PAGE_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_WEBHOOK_VERIFY_TOKEN=

# ── LinkedIn ──────────────────────────────────────────────────
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_PERSON_URN=

# ── Website / Vercel Deploy Hook ──────────────────────────────
VERCEL_DEPLOY_HOOK_URL=https://api.vercel.com/v1/integrations/deploy/...

# ── News API (optional — for AI news sourcing) ────────────────
NEWS_API_KEY=
GNEWS_API_KEY=

# ── Cloudflare AI Gateway (optional) ─────────────────────────
# Set these to route AI calls through CF AI Gateway for caching + logging
CF_AI_GATEWAY_URL=https://gateway.ai.cloudflare.com/v1/ACCOUNT_ID/propost

# ── Next.js ───────────────────────────────────────────────────
NEXTAUTH_SECRET=your-nextauth-secret
NEXTAUTH_URL=http://localhost:3000
