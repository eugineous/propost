{
  "name": "ProPost → Instagram",
  "flow": [
    {
      "id": 1,
      "module": "gateway:CustomWebHook",
      "version": 1,
      "parameters": {
        "hook": 4013187
      },
      "filter": {
        "name": "",
        "conditions": []
      },
      "mapper": {},
      "metadata": {
        "designer": { "x": 0, "y": 0 },
        "restore": {
          "parameters": {
            "hook": {
              "label": "ProPost Instagram Webhook",
              "data": { "editable": "true" }
            }
          }
        }
      }
    },
    {
      "id": 2,
      "module": "instagram-business:CreatePhotoPost",
      "version": 1,
      "parameters": {
        "connection": "__REPLACE_WITH_INSTAGRAM_CONNECTION_ID__"
      },
      "mapper": {
        "caption": "{{1.content}}",
        "imageUrl": "{{1.media_url}}"
      },
      "metadata": {
        "designer": { "x": 300, "y": 0 }
      }
    }
  ],
  "metadata": {
    "instant": true,
    "version": 1
  }
}
