{
  "functions": {
    "app/api/**": { "maxDuration": 60 },
    "app/api/workflows/**": { "maxDuration": 300 },
    "app/api/cron/**": { "maxDuration": 300 },
    "app/api/agents/work": { "maxDuration": 300 },
    "app/api/agents/startup": { "maxDuration": 60 }
  },
  "crons": [
    {
      "path": "/api/cron/daily-workflows",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/replies",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/cron/ai-news",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/analytics",
      "schedule": "0 0 * * *"
    }
  ]
}
